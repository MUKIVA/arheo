import { Button, VerticalBox, HorizontalBox, LineEdit } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "Arheo";
    preferred-width: 800px;
    preferred-height: 600px;
    background: #1e1e2e;

    VerticalBox {
        alignment: center;
        padding: 40px;
        spacing: 16px;

        Text {
            text: "Arheo";
            font-size: 48px;
            font-weight: 700;
            color: #cdd6f4;
            horizontal-alignment: center;
        }

        Text {
            text: "Welcome to Arheo";
            font-size: 18px;
            color: #a6adc8;
            horizontal-alignment: center;
        }

        Rectangle {
            height: 1px;
            background: #313244;
            max-width: 400px;
            horizontal-stretch: 0;
        }

        HorizontalBox {
            alignment: center;
            spacing: 12px;

            Button {
                text: "Get Started";
            }
        }
    }
}
